# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# AgentCore Memory ID - find this in the AgentCore Memory console
AGENTCORE_MEMORY_ID=your-memory-id-here

# Optional: override the default AgentCore Runtime IAM role (used by agentcore_deploy.py --create)
# AGENT_RUNTIME_ROLE_ARN=arn:aws:iam::123456789012:role/MyAgentCoreRole

# Tavily API Key
TAVILY_API_KEY=your-tavily-api-key-here

# Optional: default timezone for get_current_date_and_time (IANA name, e.g. America/New_York)
# AGENT_TIMEZONE=UTC